# CMake/build outputs
build/
*/build/
**/build/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
Makefile

# Compiled binaries and objects
*.o
*.a
*.so
*.so.*
*.exe

# Downloaded/compiled model artifacts
*.tar.gz
*.mpk
*.onnx
*.tflite
*.bin
*.weights
*.pptx

# Runtime logs and process files
*.log
*.pid
logs/
tmp/
.ipynb_checkpoints/

# Editor/OS noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Python cache from helper scripts
__pycache__/
*.py[cod]

# Keep model directories in git without committing model blobs.
!**/assets/
!**/assets/models/
!**/assets/models/.gitkeep

# Debug screenshots emitted by apps/*/tools probes
apps/*/tools/*.jpg
